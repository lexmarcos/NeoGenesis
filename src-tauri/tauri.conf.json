{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Neo Genesis",
  "version": "0.1.0",
  "identifier": "com.community.neogenesis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Neo Genesis",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
